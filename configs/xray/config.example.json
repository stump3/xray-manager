{
  // ════════════════════════════════════════════════════════════
  //  Xray Manager — аннотированный шаблон конфига
  //  Файл: /usr/local/etc/xray/config.json
  //
  //  Этот файл создаётся автоматически при установке ядра.
  //  Используй как справочник для ручного редактирования.
  //
  //  ВАЖНО: xray не поддерживает комментарии в JSON.
  //  Это .jsonc — только для документации.
  // ════════════════════════════════════════════════════════════

  // ── Stats API ── обязателен для трафик-статистики и лимитов
  "stats": {},

  "api": {
    "tag": "api",
    "services": ["StatsService"]
  },

  "policy": {
    "levels": {
      "0": {
        "statsUserUplink":   true,   // считать трафик ↑ на пользователя
        "statsUserDownlink": true    // считать трафик ↓ на пользователя
      }
    },
    "system": {
      "statsInboundUplink":   true,
      "statsInboundDownlink": true
    }
  },

  // ── Inbound'ы ────────────────────────────────────────────────
  "inbounds": [

    // Stats API — только localhost, порт 10085
    {
      "tag":      "api",
      "listen":   "127.0.0.1",
      "port":     10085,
      "protocol": "dokodemo-door",
      "settings": { "address": "127.0.0.1" }
    },

    // ── Пример: VLESS + TCP + REALITY ──────────────────────────
    // Генерируется через меню 2) → 1) VLESS+TCP+REALITY
    {
      "tag":      "vless-reality",
      "listen":   "0.0.0.0",
      "port":     8443,
      "protocol": "vless",
      "settings": {
        "clients": [
          {
            "email": "alice",                    // идентификатор для статистики
            "id":    "UUID",                     // xray uuid
            "flow":  "xtls-rprx-vision"          // XTLS Vision
          }
        ],
        "decryption": "none"
      },
      "streamSettings": {
        "network":  "tcp",
        "security": "reality",
        "realitySettings": {
          "show":   false,
          "target": "www.microsoft.com:443",     // камуфляжный хост (TLSv1.3+H2)
          "xver":   0,
          "serverNames": [
            "www.microsoft.com"
          ],
          "privateKey": "PRIVATE_KEY",           // xray x25519 → Private key
          "shortIds":   ["SHORT_ID"]             // openssl rand -hex 8
        }
      },
      "sniffing": {
        "enabled":     true,
        "destOverride": ["http", "tls", "quic"],
        "routeOnly":   true                      // sniff только для маршрутизации
      }
    },

    // ── Пример: VLESS + XHTTP + REALITY ────────────────────────
    // Генерируется через меню 2) → 2) VLESS+XHTTP+REALITY
    {
      "tag":      "vless-xhttp",
      "listen":   "0.0.0.0",
      "port":     8444,
      "protocol": "vless",
      "settings": {
        "clients": [
          { "email": "alice", "id": "UUID", "flow": "" }  // flow: "" — Vision несовместим с XHTTP
        ],
        "decryption": "none"
      },
      "streamSettings": {
        "network":  "xhttp",
        "security": "reality",
        "xhttpSettings": {
          "path": "/",
          "mode": "auto"                         // auto | packet-up | stream-up | stream-one
        },
        "realitySettings": {
          "show":        false,
          "target":      "www.microsoft.com:443",
          "serverNames": ["www.microsoft.com"],
          "privateKey":  "PRIVATE_KEY",
          "shortIds":    ["SHORT_ID"]
        }
      },
      "sniffing": {
        "enabled":     true,
        "destOverride": ["http", "tls", "quic"],
        "routeOnly":   true
      }
    },

    // ── Пример: VLESS + WebSocket + TLS (за Nginx) ─────────────
    // Nginx проксирует 443 → 127.0.0.1:10001
    {
      "tag":      "vless-ws",
      "listen":   "127.0.0.1",
      "port":     10001,
      "protocol": "vless",
      "settings": {
        "clients": [
          { "email": "alice", "id": "UUID" }
        ],
        "decryption": "none"
      },
      "streamSettings": {
        "network":    "ws",
        "security":   "none",                   // TLS на стороне Nginx
        "wsSettings": { "path": "/ws" }
      },
      "sniffing": {
        "enabled":     true,
        "destOverride": ["http", "tls"]
      }
    },

    // ── Пример: Hysteria2 (нативный Xray) ──────────────────────
    {
      "tag":      "hy2-inbound",
      "listen":   "0.0.0.0",
      "port":     443,
      "protocol": "vless",
      "settings": {
        "users": [                               // settings.users, не clients
          { "email": "alice", "password": "PASSWORD" }
        ]
      },
      "streamSettings": {
        "network":    "hysteria",
        "security":   "tls",
        "tlsSettings": {
          "serverName":   "DOMAIN",
          "certificates": [
            {
              "certificateFile": "/etc/letsencrypt/live/DOMAIN/fullchain.pem",
              "keyFile":         "/etc/letsencrypt/live/DOMAIN/privkey.pem"
            }
          ]
        },
        "hysteriaSettings": {
          "version": 2,
          "up":      "0",                        // "0" = BBR; "50 mbps" = Brutal
          "down":    "0",
          "udphop":  {                           // Port Hopping (опционально)
            "port":     "20000-29999",
            "interval": 30
          }
        }
      }
    }

  ],

  // ── Outbound'ы ───────────────────────────────────────────────
  "outbounds": [
    { "protocol": "freedom",   "tag": "direct" },
    { "protocol": "blackhole", "tag": "block"  }
  ],

  // ── Маршрутизация ────────────────────────────────────────────
  "routing": {
    "domainStrategy": "IPIfNonMatch",    // AsIs | IPIfNonMatch | IPOnDemand
    "rules": [

      // Stats API — обязательное правило
      {
        "type":        "field",
        "inboundTag":  ["api"],
        "outboundTag": "api"
      },

      // Блокировка приватных IP (защита от SSRF)
      {
        "type":        "field",
        "ip":          ["geoip:private"],
        "outboundTag": "block"
      }

      // Дополнительные правила добавляются через меню R) Маршрутизация
    ]
  }
}
